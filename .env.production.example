# Copy these into your hosting provider's environment-variable panel.
# Do not commit real secrets to GitHub.
SECRET_KEY=generate-a-long-random-secret-key
DEBUG=False
ALLOWED_HOSTS=your-app.onrender.com,yourdomain.com,www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com,https://yourdomain.com,https://www.yourdomain.com

# Use the DATABASE_URL provided by Render/Railway PostgreSQL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DB_SSL_REQUIRE=True
DB_CONN_MAX_AGE=600

# Free testing stack for launch.
MAP_PROVIDER=osm
GEOCODER_PROVIDER=nominatim
AI_PROVIDER=gemini
GEMINI_API_KEY=paste-your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash

# Persistent media location. Render persistent disk example:
MEDIA_ROOT=/var/data/rentwise_media
MEDIA_URL=/media/

# Automatic listing-photo compression.
RENTWISE_MAX_IMAGE_UPLOAD_MB=8
RENTWISE_IMAGE_MAX_WIDTH=1600
RENTWISE_IMAGE_MAX_HEIGHT=1200
RENTWISE_IMAGE_JPEG_QUALITY=80


# Optional Cloudflare R2 image storage. Turn this on after creating your R2 bucket.
USE_S3_MEDIA=False
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_REGION=auto
CLOUDFLARE_R2_MEDIA_PREFIX=media
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# HTTPS/security.
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Optional error monitoring. Leave blank until you create a Sentry project.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
DJANGO_LOG_LEVEL=INFO

# Optional backup folder for `python manage.py backup_data`.
BACKUP_DIR=/var/data/rentwise_backups
